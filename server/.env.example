# ============================================
# Legistra Server - Production Configuration
# ============================================

# Ambiente
NODE_ENV=production

# Server
PORT=3001

# CORS - Domini autorizzati (separati da virgola)
CORS_ORIGINS=https://tuodominio.it,https://www.tuodominio.it

# ============================================
# API Keys
# ============================================

# OpenAI (obbligatorio per AI features)
OPENAI_API_KEY=sk-proj-...

# Gemini (gratuito, usato per OCR)
GEMINI_API_KEY=AIza...

# ============================================
# Supabase (Database & Auth)
# ============================================

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJ...
SUPABASE_SERVICE_KEY=eyJhbGciOiJ...  # Solo per server

# ============================================
# Storage (opzionale, default: locale)
# ============================================

# Abilita storage cloud su Supabase Storage
USE_CLOUD_STORAGE=true
STORAGE_BUCKET=documents

# ============================================
# Redis (opzionale, per scalabilità)
# ============================================

# Se non configurato, usa in-memory queue
# REDIS_URL=redis://localhost:6379

# ============================================
# Monitoraggio (opzionale)
# ============================================

# Sentry per error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
