      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "// Rinominare i campi binari di tutti gli item in 'file'\nconst items = $input.all();\nreturn items.map(item => {\n  const binKey = Object.keys(item.binary || {})[0];\n  if (binKey && binKey !== 'file') {\n    item.binary.file = item.binary[binKey];\n    delete item.binary[binKey];\n  }\n  return item;\n});"
      },
