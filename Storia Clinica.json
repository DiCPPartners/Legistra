    {
      "parameters": {
        "jsCode": "// Estrae e concatena il testo OCR da tutti i PDF\nconst all = $input.all();\n\nconst combined = all.map(item => {\n  // cerca il testo OCR nel campo pages[0].markdown\n  if (item.json.pages && item.json.pages[0]?.markdown) {\n    return item.json.pages[0].markdown;\n  }\n  // fallback: altri campi comuni\n  return item.json.text || item.json.result || \"\";\n}).join(\"\\n\\n---\\n\\n\");\n\nreturn [{ json: { full_text: combined } }];"
      },
      "type": "n8n-nodes-base.code",
