    {
      "parameters": {
        "jsCode": "// Estrae e concatena il testo OCR da tutti i PDF\nconst all = $input.all();\n\nconst combined = all.map(item => {\n  // cerca il testo OCR nel campo pages[0].markdown\n  if (item.json.pages && item.json.pages[0]?.markdown) {\n    return item.json.pages[0].markdown;\n  }\n  // fallback: altri campi comuni\n  return item.json.text || item.json.result || \"\";\n}).join(\"\\n\\n---\\n\\n\");\n\nreturn [{ json: { full_text: combined } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        32
      ],
      "id": "fb7e1c54-0bad-4df7-b997-3702863bd6ff",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "// Rinominare i campi binari di tutti gli item in 'file'\nconst items = $input.all();\nreturn items.map(item => {\n  const binKey = Object.keys(item.binary || {})[0];\n  if (binKey && binKey !== 'file') {\n    item.binary.file = item.binary[binKey];\n    delete item.binary[binKey];\n  }\n  return item;\n});"
      },
